# Local Supabase/Postgres. Supabase CLI default is usually port 54322.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-local-secret
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=homeboard
ENCRYPTION_KEY=replace-with-32-byte-local-key

# Experimental local file database path for future no-Supabase mode.
# Current stable mode still uses DATABASE_URL/Postgres.
LOCAL_DB_PATH=./data/openwallcal.db
